# ============================================================
# FORGE Cluster A — Geometry Kernel
# .env.example
#
# Copy to .env and customize for your environment.
# Never commit .env with real secrets to version control.
#
# Usage:
#   cp .env.example .env
#   docker-compose --profile individual up
# ============================================================

# ── Build metadata ────────────────────────────────────────────
# Git commit SHA injected at build time (for /version endpoint)
GIT_COMMIT=unknown

# ── Service versions ──────────────────────────────────────────
CADQUERY_VERSION=2.2.0
PARAMAK_VERSION=2.2.0
PARASTELL_VERSION=2.2.0
PICOGK_VERSION=1.1.0
UNIFIED_VERSION=2.2.0

# ── Port mappings (host:container) ───────────────────────────
# Individual mode ports:
CADQUERY_PORT=8002
PARAMAK_PORT=8006
PARASTELL_PORT=8007
PICOGK_PORT=8015

# Unified mode port:
UNIFIED_PORT=8020

# ── Timeout (seconds) ─────────────────────────────────────────
# Maximum time for a single geometry generation request
FORGE_TIMEOUT=300

# ── Memory limits ─────────────────────────────────────────────
# Docker resource limits per container
CADQUERY_MEMORY=1500m
PARAMAK_MEMORY=1500m
PARASTELL_MEMORY=2000m
PICOGK_MEMORY=1000m

# Unified container memory (all engines combined — allocate generously)
UNIFIED_MEMORY=4000m

# ── PicoGK-specific ───────────────────────────────────────────
# Voxel resolution in mm (smaller = more detail, more memory)
PICOGK_VOXEL_SIZE=0.2

# ── Data directory (inside container) ─────────────────────────
# Override the internal data directory for geometry outputs
# FORGE_DATA_DIR=/opt/forge/data  # (default, usually no need to change)
